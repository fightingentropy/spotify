{
  "name": "spotify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run lint && bun run typecheck && bun test && bun run build",
    "dev": "vite dev",
    "start": "vite preview",
    "lint": "eslint .",
    "preview": "vite preview",
    "local:music": "bun run src/server/local-music-server.ts",
    "mini:deploy": "bash scripts/deploy-mini.sh",
    "mini:install-caddy": "bash scripts/install-mini-caddy.sh",
    "mini:install-dns-watch": "bash scripts/install-mini-dns-watch.sh",
    "mini:install-server": "bash scripts/install-mini-server.sh",
    "mini:sync-music": "bash scripts/sync-mini-music.sh",
    "mini:check": "bash scripts/check-mini.sh",
    "deploy": "vite build && wrangler deploy",
    "upload": "vite build && wrangler deploy --dry-run",
    "download:liked": "bun scripts/download-liked-to-music.ts",
    "icons": "bun scripts/generate-icons.ts",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "hls.js": "^1.6.16",
    "hono": "^4.12.23",
    "lucide-react": "^0.575.0",
    "music-metadata": "11.12.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "baseline-browser-mapping": "^2.10.34",
    "bun-types": "^1.3.14",
    "eslint": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "wrangler": "^4.98.0"
  },
  "overrides": {
    "baseline-browser-mapping": "^2.10.0",
    "flatted": "3.4.2"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "sharp",
    "unrs-resolver"
  ]
}
