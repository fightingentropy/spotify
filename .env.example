# Core
DATABASE_URL=postgres://waveform:waveform@localhost:5432/waveform
# Generate secrets with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_me
ADMIN_SECRET=replace_me

# MinIO
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=waveform
MINIO_SECRET_KEY=waveformsecret
MINIO_BUCKET=uploads

# Upload limits (bytes)
UPLOAD_MAX_IMAGE_BYTES=5242880
UPLOAD_MAX_AUDIO_BYTES=52428800

# Rate limiting
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=300000
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW_MS=600000
RATE_LIMIT_ADMIN_MAX=30
RATE_LIMIT_ADMIN_WINDOW_MS=60000
