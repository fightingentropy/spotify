# Cloudflare bindings are configured in wrangler.jsonc and simulated by Wrangler during local dev.

# Local Mac mini music server
HOST=0.0.0.0
PORT=5174
SPOTIFY_MUSIC_DIR=/Users/hermes/Music
SPOTIFY_DIST_DIR=/Users/hermes/Developer/spotify/dist/client
SPOTIFY_CACHE_DIR=/Users/hermes/Developer/spotify/cache
SPOTIFY_ARTWORK_LOOKUP=1
SPOTIFY_ARTWORK_COUNTRY=GB
# Must match MAC_MINI_PROXY_TOKEN in the Worker secret store.
SPOTIFY_PROXY_TOKEN=
SPOTIFY_PROXY_HOSTNAMES=spotify.fightingentropy.org
# Accounts allowed to see/mutate the Mac mini music folder. Prefer email or
# user id; names are a convenience fallback for this private deployment.
SPOTIFY_LIBRARY_OWNER_EMAILS=
SPOTIFY_LIBRARY_OWNER_USER_IDS=
SPOTIFY_LIBRARY_OWNER_NAMES=Erlin

# Optional Mac mini DNS drift watcher for the direct Caddy hostname. The watcher
# only logs drift; it does not mutate Cloudflare DNS.
SPOTIFY_DNS_WATCH_NAME=spotify.fightingentropy.org

# Cloudflare Worker -> Mac mini music storage through direct home Caddy.
# Operational SSH scripts try m4mini-ts, Tailscale IP, m4mini.local, then LAN IP.
MAC_MINI_ORIGIN=https://spotify.fightingentropy.org
MAC_MINI_PROXY_TOKEN=

# Email verification (Cloudflare Email Service). Requires the "EMAIL" send_email
# binding (in wrangler.jsonc) plus a verified sending domain on the Workers paid
# plan. The feature gracefully no-ops until the binding is configured.
# EMAIL_FROM: the verified sender address. APP_ORIGIN: base URL for the
# verification link (defaults to MAC_MINI_ORIGIN, then the request origin).
EMAIL_FROM=noreply@fightingentropy.org
APP_ORIGIN=https://spotify.fightingentropy.org

# Optional licensed audio source provider. The Worker POSTs Spotify metadata to
# this endpoint and expects JSON with streamUrl/audioUrl/downloadUrl/url.
LICENSED_SOURCE_PROVIDER_URL=
LICENSED_SOURCE_PROVIDER_API_KEY=
LICENSED_SOURCE_PROVIDER_USER_AGENT=
LICENSED_SOURCE_PROVIDER_RESOLVE_TIMEOUT_MS=8000

# Optional Qobuz app credentials. Local dev can mirror these from a licensed
# provider config instead of relying on scraped/default credentials.
QOBUZ_APP_ID=
QOBUZ_APP_SECRET=

# Optional SpotiFLAC mirror settings. Auto mode follows this order when set.
SPOTIFLAC_PROVIDER_ORDER=tidal-tidal_x-tidal_custom-qobuz-qobuz_x-qobuz_custom-amazon-amazon_x-deezer-deezer_x-deezer_custom-apple
SPOTIFLAC_STATUS_CHECKS=1
SPOTIFLAC_STATUS_URL=https://spotbye.qzz.io/api/status
SPOTIFLAC_TIDAL_APIS=
SPOTIFLAC_ACTIVE_TIDAL_API=

# Optional per-provider licensed resolver slots. Each endpoint should return
# the same stream JSON shape as LICENSED_SOURCE_PROVIDER_URL.
SPOTIFLAC_TIDAL_CUSTOM_PROVIDER_URL=
SPOTIFLAC_QOBUZ_X_PROVIDER_URL=
SPOTIFLAC_QOBUZ_CUSTOM_PROVIDER_URL=
SPOTIFLAC_AMAZON_PROVIDER_URL=
SPOTIFLAC_AMAZON_X_PROVIDER_URL=
SPOTIFLAC_DEEZER_PROVIDER_URL=
SPOTIFLAC_DEEZER_X_PROVIDER_URL=
SPOTIFLAC_DEEZER_CUSTOM_PROVIDER_URL=
SPOTIFLAC_APPLE_PROVIDER_URL=

# Smart Shuffle recommender. A free Last.fm API key (https://www.last.fm/api)
# powers seed-based "similar track" recommendations for the in-app Smart Shuffle
# mode. When unset, POST /api/smart-shuffle/recommend returns no recommendations
# (reason "no-recommender-configured") and the feature stays dormant.
LAST_FM_API_KEY=
