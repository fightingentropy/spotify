# Cloudflare bindings are configured in wrangler.jsonc and simulated by Wrangler during local dev.

# Local Mac mini music server
HOST=0.0.0.0
PORT=5174
SPOTIFY_MUSIC_DIR=/Users/hermes/Music
SPOTIFY_DIST_DIR=/Users/hermes/Developer/spotify/dist/client
SPOTIFY_CACHE_DIR=/Users/hermes/Developer/spotify/cache
SPOTIFY_ARTWORK_LOOKUP=1
SPOTIFY_ARTWORK_COUNTRY=GB
# Must match MAC_MINI_PROXY_TOKEN in the Worker secret store.
SPOTIFY_PROXY_TOKEN=
SPOTIFY_PROXY_HOSTNAMES=spotify.fightingentropy.org
# Accounts allowed to see/mutate the Mac mini music folder. Prefer email or
# user id; names are a convenience fallback for this private deployment.
SPOTIFY_LIBRARY_OWNER_EMAILS=
SPOTIFY_LIBRARY_OWNER_USER_IDS=
SPOTIFY_LIBRARY_OWNER_NAMES=Erlin

# Optional Mac mini DNS drift watcher for the direct Caddy hostname. The watcher
# only logs drift; it does not mutate Cloudflare DNS.
SPOTIFY_DNS_WATCH_NAME=spotify.fightingentropy.org

# Cloudflare Worker -> Mac mini music storage through direct home Caddy.
# Operational SSH scripts try m4mini-ts, Tailscale IP, m4mini.local, then LAN IP.
MAC_MINI_ORIGIN=https://spotify.fightingentropy.org
MAC_MINI_PROXY_TOKEN=
