{
	"$schema": "node_modules/wrangler/config-schema.json",
	"main": "src/worker/index.ts",
	"name": "spotify",
	"workers_dev": true,
	"compatibility_date": "2026-05-23",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"triggers": {
		"crons": ["*/15 * * * *"]
	},
	"assets": {
		"binding": "ASSETS",
		"not_found_handling": "single-page-application"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "spotify-db",
			"database_id": "88a7aea6-ab87-43e9-a728-bca750986ccc"
		}
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "spotify-media"
		}
	],
	"images": {
		"binding": "IMAGES"
	},
	"send_email": [
		{
			"name": "EMAIL"
		}
	],
	"observability": {
		"enabled": true
	},
	"vars": {
		"AUTH_TRUST_HOST": "true",
		"EMAIL_FROM": "noreply@fightingentropy.org",
		"MAC_MINI_ORIGIN": "https://spotify.fightingentropy.org",
		"SPOTIFLAC_PROVIDER_ORDER": "tidal-tidal_x-tidal_custom-qobuz-qobuz_x-qobuz_custom-amazon-amazon_x-deezer-deezer_x-deezer_custom-apple",
		"SPOTIFLAC_TIDAL_APIS": "https://tdl-a.spotbye.qzz.io,https://tdl-b.spotbye.qzz.io,https://tdl-c.spotbye.qzz.io,https://tdl-d.spotbye.qzz.io,https://tdl-e.spotbye.qzz.io",
		"SPOTIFLAC_ACTIVE_TIDAL_API": "https://tdl-a.spotbye.qzz.io"
	}
}
